{
  "mcpServers": {
    "connectwise-automate": {
      "type": "http",
      "url": "${CONNECTWISE_AUTOMATE_MCP_URL}",
      "headers": {
        "X-CWA-Server": "${CW_AUTOMATE_SERVER_URL}",
        "X-CWA-Client-ID": "${CW_AUTOMATE_CLIENT_ID}",
        "X-CWA-Username": "${CW_AUTOMATE_USERNAME}",
        "X-CWA-Password": "${CW_AUTOMATE_PASSWORD}"
      }
    }
  }
}
