{
  "mcpServers": {
    "quickbooks-online": {
      "command": "npx",
      "args": ["-y", "quickbooks-online-mcp-server@latest"],
      "env": {
        "QBO_CLIENT_ID": "${QBO_CLIENT_ID}",
        "QBO_CLIENT_SECRET": "${QBO_CLIENT_SECRET}"
      },
      "note": "Intuit official MCP server (early preview): https://github.com/intuit/quickbooks-online-mcp-server"
    }
  }
}
