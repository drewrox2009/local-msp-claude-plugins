{
  "manifest_version": "0.3",
  "name": "repairshopr-mcp",
  "display_name": "RepairShopr MCP Server",
  "version": "0.0.0",
  "description": "MCP server for RepairShopr - access tickets, customers, assets, and invoices through AI assistants",
  "long_description": "Provides AI assistants with structured access to your RepairShopr data. Manage tickets, customers, assets, invoices, and more through the Model Context Protocol.",
  "author": { "name": "MSP Claude Plugins Community", "url": "https://github.com/drewrox2009/local-msp-claude-plugins" },
  "repository": { "type": "git", "url": "https://github.com/drewrox2009/local-msp-claude-plugins" },
  "homepage": "https://github.com/drewrox2009/local-msp-claude-plugins/tree/main/msp-claude-plugins/mcp-servers/repairshopr-mcp",
  "license": "Apache-2.0",
  "keywords": ["repairshopr", "msp", "rmm", "psa", "tickets", "it-management"],
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/index.js"],
      "env": { "REPAIRSHOPR_API_KEY": "${user_config.repairshopr_api_key}", "REPAIRSHOPR_SUBDOMAIN": "${user_config.repairshopr_subdomain}", "MCP_TRANSPORT": "stdio" }
    }
  },
  "tools_generated": true,
  "user_config": {
    "repairshopr_api_key": { "type": "string", "title": "RepairShopr API Key", "description": "Your RepairShopr API key", "sensitive": true, "required": true },
    "repairshopr_subdomain": { "type": "string", "title": "RepairShopr Subdomain", "description": "Your RepairShopr subdomain (optional)", "sensitive": false, "required": false }
  },
  "compatibility": { "platforms": ["darwin", "win32", "linux"], "runtimes": { "node": ">=18.0.0" }, "claude_desktop": ">=0.10.0" }
}
