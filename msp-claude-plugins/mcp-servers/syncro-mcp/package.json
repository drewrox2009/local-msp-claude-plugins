{
  "name": "syncro-mcp",
  "version": "1.1.3",
  "description": "Syncro MSP MCP server for Claude",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "syncro-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:mcpb": "node scripts/pack-mcpb.js",
    "validate:mcpb": "mcpb validate manifest.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drewrox2009/local-msp-claude-plugins.git"
  },
  "keywords": [
    "mcp",
    "claude",
    "syncro",
    "syncro-msp",
    "msp",
    "psa",
    "rmm"
  ],
  "author": "MSP Claude Plugins Community",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/drewrox2009/local-msp-claude-plugins/issues"
  },
  "homepage": "https://github.com/drewrox2009/local-msp-claude-plugins/tree/main/msp-claude-plugins/mcp-servers/syncro-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "semantic-release": "^25.0.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
