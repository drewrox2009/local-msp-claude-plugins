---
import DocsLayout from '@/layouts/DocsLayout.astro';
import { prompts, roleLabels, roleDescriptions, roleOrder, getPromptsByRole } from '@/data/prompts';
import { plugins } from '@/data/plugins';

const baseUrl = import.meta.env.BASE_URL;

const roleIcons: Record<string, string> = {
  account: '🤝',
  finance:  '💰',
  sales:    '📈',
  support:  '🎧',
  noc:      '🖥️',
};

function getPluginNames(pluginIds: string[]): string {
  if (pluginIds.length === 0) return 'Any PSA / RMM';
  return pluginIds
    .map(id => plugins.find(p => p.id === id)?.name ?? id)
    .join(', ');
}
---

<DocsLayout title="Prompt Bank" description="Ready-to-use prompts for MSP teams — account management, finance, sales, support, and NOC.">
  <h1>Prompt Bank</h1>

  <p class="lead text-lg text-[var(--muted)] mb-8">
    Ready-to-use prompts for every MSP team. Copy, fill in the brackets, and go.
    There are {prompts.length} prompts across {roleOrder.length} roles.
  </p>

  <div class="not-prose mb-8 flex flex-wrap gap-2">
    {roleOrder.map(role => (
      <a
        href={`#${role}`}
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium bg-[var(--surface)] border border-[var(--border)] hover:border-[var(--link)] hover:text-[var(--link)] transition-colors"
      >
        <span>{roleIcons[role]}</span>
        <span>{roleLabels[role]}</span>
      </a>
    ))}
  </div>

  <hr />

  {roleOrder.map(role => {
    const rolePrompts = getPromptsByRole(role);
    return (
      <section id={role} class="mb-12">
        <h2>
          <span class="mr-2">{roleIcons[role]}</span>
          {roleLabels[role]}
        </h2>
        <p class="text-[var(--muted)]">{roleDescriptions[role]}</p>

        <div class="not-prose space-y-6 mt-6">
          {rolePrompts.map(prompt => (
            <div class="rounded-lg border border-[var(--border)] bg-[var(--surface)] overflow-hidden">
              <div class="px-5 py-4 border-b border-[var(--border)] flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-semibold text-[var(--text)] text-base mb-1">{prompt.title}</h3>
                  <p class="text-sm text-[var(--muted)]">{prompt.description}</p>
                </div>
                <span class="shrink-0 text-xs text-[var(--muted)] bg-[var(--bg)] border border-[var(--border)] rounded px-2 py-1 whitespace-nowrap">
                  {getPluginNames(prompt.plugins)}
                </span>
              </div>
              <div class="relative group">
                <pre class="m-0 p-5 text-sm overflow-x-auto bg-transparent rounded-none border-none whitespace-pre-wrap leading-relaxed"><code>{prompt.prompt}</code></pre>
                <button
                  class="copy-btn absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity px-2.5 py-1.5 text-xs font-medium rounded bg-[var(--bg)] border border-[var(--border)] hover:border-[var(--link)] hover:text-[var(--link)]"
                  data-prompt={prompt.prompt}
                  aria-label="Copy prompt"
                >
                  Copy
                </button>
              </div>
            </div>
          ))}
        </div>
      </section>
    );
  })}

  <hr />

  <h2>Tips for Better Results</h2>

  <h3>Always specify the client</h3>
  <p>Replace <code>[CLIENT NAME]</code> with the actual company name. Claude will use it to filter data across all connected tools.</p>

  <h3>Set the time range</h3>
  <p>Prompts with <code>[DATE RANGE]</code> or <code>[MONTH]</code> work best with specific dates — "March 1–31 2025" is better than "last month."</p>

  <h3>Chain prompts for deeper analysis</h3>
  <p>Start with a summary prompt, then ask follow-up questions. Claude maintains context across the conversation:</p>
  <pre><code class="language-text"># First: run the QBR Client Summary prompt for Acme Corp
# Then follow up:
Which of those recurring issues could we have prevented with proactive monitoring?</code></pre>

  <h3>Combine skills for cross-platform workflows</h3>
  <p>Load relevant skills before running a cross-platform prompt:</p>
  <pre><code class="language-text">/skill autotask:tickets
/skill ninjaone:devices

Now run the Client Health Scorecard prompt for Acme Corp.</code></pre>

</DocsLayout>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-prompt') ?? '';
      await navigator.clipboard.writeText(text);
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
  });
</script>
