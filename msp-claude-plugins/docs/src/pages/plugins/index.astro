---
import DocsLayout from '@/layouts/DocsLayout.astro';
import PluginCard from '@/components/PluginCard.astro';
import { plugins, getPluginsByCategory } from '@/data/plugins';

const psaPlugins = getPluginsByCategory('psa');
const rmmPlugins = getPluginsByCategory('rmm');
const docPlugins = getPluginsByCategory('documentation');
const securityPlugins = getPluginsByCategory('security');
const salesPlugins = getPluginsByCategory('sales');
const accountingPlugins = getPluginsByCategory('accounting');
---

<DocsLayout title="Plugin Catalog">
  <h1>Plugin Catalog</h1>

  <p class="lead text-lg text-[var(--muted)] mb-8">
    Browse all {plugins.length} MSP Claude Plugins. Each plugin provides skills,
    commands, and deep API knowledge for its platform.
  </p>

  <h2>RMM ({rmmPlugins.length})</h2>

  <p>Remote Monitoring and Management plugins for device management, alerts, and automation.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose my-6">
    {rmmPlugins.map(plugin => (
      <PluginCard plugin={plugin} />
    ))}
  </div>

  <h2>PSA ({psaPlugins.length})</h2>

  <p>Professional Services Automation plugins for ticket management, CRM, and billing.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose my-6">
    {psaPlugins.map(plugin => (
      <PluginCard plugin={plugin} />
    ))}
  </div>

  <h2>IT Documentation ({docPlugins.length})</h2>

  <p>Documentation and knowledge base plugins for asset tracking, password management, and configuration monitoring.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose my-6">
    {docPlugins.map(plugin => (
      <PluginCard plugin={plugin} />
    ))}
  </div>

  <h2>Security ({securityPlugins.length})</h2>

  <p>Security and SOC plugins for incident management, threat detection, and compliance.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose my-6">
    {securityPlugins.map(plugin => (
      <PluginCard plugin={plugin} />
    ))}
  </div>

  <h2>Sales & Distribution ({salesPlugins.length})</h2>

  <p>CRM, quoting, document automation, and cloud marketplace plugins for sales pipelines, proposals, and licensing.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose my-6">
    {salesPlugins.map(plugin => (
      <PluginCard plugin={plugin} />
    ))}
  </div>

  <h2>Accounting & Finance ({accountingPlugins.length})</h2>

  <p>Accounting and financial plugins for invoicing, payments, and reporting.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 not-prose my-6">
    {accountingPlugins.map(plugin => (
      <PluginCard plugin={plugin} />
    ))}
  </div>

  <h2>All Plugins at a Glance</h2>

  <table>
    <thead>
      <tr>
        <th>Plugin</th>
        <th>Vendor</th>
        <th>Category</th>
        <th>Skills</th>
        <th>Commands</th>
      </tr>
    </thead>
    <tbody>
      {plugins.map(plugin => (
        <tr>
          <td><a href={`${import.meta.env.BASE_URL}plugins/${plugin.id}/`}>{plugin.name}</a></td>
          <td>{plugin.vendor}</td>
          <td>{{psa: 'PSA', rmm: 'RMM', documentation: 'IT Documentation', security: 'Security', sales: 'Sales & Distribution', accounting: 'Accounting & Finance'}[plugin.category]}</td>
          <td>{plugin.skills.length}</td>
          <td>{plugin.commands.length}</td>
        </tr>
      ))}
    </tbody>
  </table>
</DocsLayout>
