{
  "mcpServers": {
    "pax8": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.pax8.com/v1/mcp",
        "--header",
        "x-pax8-mcp-token:${PAX8_MCP_TOKEN}"
      ],
      "note": "Uses Pax8's official hosted MCP server. Generate token at app.pax8.com/integrations/mcp"
    }
  }
}
