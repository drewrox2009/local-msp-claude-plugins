# RepairShopr API Configuration
# Copy this file to .env and fill in your credentials

# Your RepairShopr subdomain (required)
# This is the subdomain from your RepairShopr URL: https://{subdomain}.repairshopr.com
REPAIRSHOPR_SUBDOMAIN=your-subdomain

# API Key (required)
# Generate from Admin > API Tokens in your RepairShopr dashboard
REPAIRSHOPR_API_KEY=your-api-key
